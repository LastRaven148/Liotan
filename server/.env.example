PORT=3001

MONGO_URI=mongodb://127.0.0.1:27017/Liotan

JWT_SECRET=replace_with_long_random_secret
CLIENT_URL=http://localhost:3000
PRIVACY_HASH_SECRET=change_me_long_random_secret

# Email codes. Recommended free start: Resend.
# Use a verified sender/domain, for example: Liotan <auth@your-domain.com>
RESEND_API_KEY=
MAIL_FROM=
MAIL_REPLY_TO=no-reply@your-domain.com

# Optional SMTP fallback instead of Resend.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# One-time cleanup script controls.
# Do not keep these enabled forever.
LIOTAN_DELETE_LEGACY_WITHOUT_EMAIL=false
LIOTAN_CLEANUP_USERNAMES=
LIOTAN_CLEANUP_EMAILS=
