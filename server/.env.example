PORT=3001
NODE_ENV=production

CLIENT_URL=https://liotan.com
PUBLIC_CLIENT_URL=https://liotan.com
API_URL=http://127.0.0.1:3001
PUBLIC_API_URL=https://api.liotan.com
PUBLIC_SECURITY_URL=https://security.liotan.com
# Tunnel test API: https://api-tunnel.liotan.com
ALLOWED_ORIGINS=https://liotan.com,https://www.liotan.com,https://tunnel.liotan.com,https://liotan.ru,https://www.liotan.ru
# Use only for temporary migration exceptions. Leave empty in normal production.
LEGACY_ALLOWED_ORIGINS=

MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/liotan
JWT_SECRET=replace_with_64_plus_random_chars
PRIVACY_HASH_SECRET=replace_with_64_plus_random_chars
AUTH_COOKIE_NAME=liotan_auth
AUTH_COOKIE_DOMAIN=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=liotan-uploads
R2_PUBLIC_URL=https://media.liotan.ru
LEGACY_R2_PUBLIC_URL=https://media.liotan.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Liotan <no-reply@liotan.ru>
MAIL_FROM=Liotan <security@liotan.ru>
MAIL_REPLY_TO=

MAX_ATTACHMENT_SIZE_BYTES=52428800
EMAIL_REQUIRE_MX=true
BLOCKED_EMAIL_DOMAINS=

# Privacy-first defaults. Leave these values as-is for production privacy hardening.
PRIVACY_MINIMAL_LOGS=true
PRIVACY_LOG_IP_HASH=false
PRIVACY_LOG_USER_HANDLE=false
PRIVACY_LOG_QUERY_STRING=false
PRIVACY_STORE_USER_AGENT_HASH=false
PRIVACY_STORE_DERIVED_DEVICE_NAME=false
PRIVACY_GENERIC_AUTH_ERRORS=true
PRIVACY_GENERIC_EMAIL_SUBJECTS=true
PRIVACY_EXPOSE_DEV_EMAIL_CODES=false
EMAIL_CODE_TTL_SECONDS=600

# Session privacy/security
SESSION_MAX_ACTIVE_PER_USER=10
SESSION_TTL_DAYS=30
SESSION_TOUCH_THROTTLE_MS=300000
SESSION_CLEANUP_BATCH_SIZE=500
PRIVACY_ANONYMIZE_UPLOAD_FOLDERS=true
PRIVACY_EXPOSE_DEVICE_NAMES_TO_CONTACTS=false
PRIVACY_EXPOSE_E2EE_USER_ENUMERATION=false

# Required in production for TOTP, vault, recovery and pending email-change envelopes.
# Use a random value with at least 32 characters. Do not reuse JWT_SECRET.
SECURITY_ENCRYPTION_SECRET=

# High-risk operations may require recent login/2FA after this window.
RECENT_AUTH_WINDOW_MINUTES=15

# Email changes are pending and cancellable during this security window.
EMAIL_CHANGE_SECURITY_WINDOW_HOURS=72
EMAIL_CHANGE_CANCEL_WINDOW_HOURS=72
