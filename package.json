{
  "name": "Liotan",
  "version": "49.0.10",
  "type": "commonjs",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "server": "node server/server.js",
    "client": "cd client && npm start",
    "build-client": "cd client && npm run build",
