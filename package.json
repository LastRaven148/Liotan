{
  "name": "Liotan",
  "version": "50.1.0",
  "license": "GPL-3.0-only",
  "type": "commonjs",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "server": "node server/server.js",
    "client": "cd client && npm start",
    "build-client": "cd client && npm run build",
    "check:client": "cd client && npm run build",
    "check:server": "cd server && npm run check",
    "check": "npm run check:client && npm run check:server",
    "audit:privacy": "cd server && npm run audit:privacy",
    "make-release": "node scripts/makeRelease.js",
    "release:check": "node scripts/checkRelease.js",
    "audit:vps": "cd server && npm run audit:vps",
    "audit:e2ee-replies": "cd server && npm run audit:e2ee-replies",
    "audit:architecture": "node scripts/architectureMap.js",
    "audit:css": "node scripts/cssArchitectureGate.js",
    "test:css-reproducible": "node scripts/cssBuildReproducibility.js",
    "test:release-reproducible": "node scripts/releaseReproducibility.js",
    "test:crypto-static": "node scripts/cryptoStaticAnalysis.js",
    "test:unit": "npm run test:unit --prefix server && npm run test:coverage",
    "test:integration": "npm run test:integration --prefix server",
    "test:crypto": "npm run test:crypto-static && npm run test:security && npm run test:media-storage && playwright test client/test/browser/mls-core.spec.js",
    "test:security": "node scripts/securityRegression.js",
    "test:media-storage": "node scripts/mediaStorageRegression.js",
    "test:deploy-installer": "bash scripts/deployInstallerPreflightRegression.sh",
    "test:deployment-bundle": "node scripts/deploymentBundleRegression.js",
    "test:archive-factory": "node scripts/archiveFactoryRegression.js",
    "test:server": "npm test --prefix server",
    "test:browser": "playwright test",
    "test:e2e": "npm run test:browser",
    "test:release": "npm run release:check",
    "test:coverage": "c8 --check-coverage --lines 80 --functions 80 --branches 70 --reporter=text --reporter=json-summary --include=server/utils/canonicalJson.js --include=server/security/cryptoV4.js node --test server/test/unit/cryptoPrimitives.test.js",
    "test": "npm run audit:css && npm run test:crypto-static && npm run test:security && npm run test:media-storage && npm run test:deploy-installer && npm run test:archive-factory && npm run test:server && npm run test:browser && npm run test:deployment-bundle && npm run test:coverage",
    "test:all": "npm test && npm run check && npm run supply-chain",
    "licenses:check": "node scripts/checkLicenses.js",
    "sbom:generate": "node scripts/generateSbom.js",
    "test:sbom-reproducible": "node scripts/sbomReproducibility.js",
    "supply-chain": "npm run licenses:check && npm run sbom:generate"
  },
  "devDependencies": {
    "@babel/parser": "8.0.4",
    "@cyclonedx/cyclonedx-npm": "6.0.0",
    "@playwright/test": "1.61.1",
    "archiver": "8.0.0",
    "c8": "11.0.0",
    "socket.io-client": "4.8.3",
    "yauzl": "3.4.0"
  }
}
