# Local development
VITE_API_URL=http://localhost:3001

# Production:
# Leave VITE_API_URL unset in production so the client chooses API by current domain:
#   https://liotan.com        -> https://api.liotan.com
#   https://tunnel.liotan.com -> https://api-tunnel.liotan.com
#   https://liotan.ru         -> https://api.liotan.ru

# Optional comma-separated backup API endpoints.
VITE_API_FALLBACK_URLS=https://api.liotan.com,https://api-tunnel.liotan.com,https://api.liotan.ru

# Media CDN / public object storage domains.
VITE_MEDIA_URL=https://media.liotan.ru
VITE_MEDIA_URLS=https://media.liotan.ru,https://media.liotan.com
